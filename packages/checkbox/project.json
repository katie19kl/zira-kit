{
  "name": "checkbox",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/checkbox/src",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["dist/{projectRoot}"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": [],
  "targets": {
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "compile": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "packages/checkbox/dist",
        "config": "packages/checkbox/rollup.config.cjs",
        "tsConfig": "packages/checkbox/tsconfig.lib.json",
        "project": "packages/checkbox/package.json",
        "entryFile": "packages/checkbox/src/index.ts"
      }
    },
    "post-compile": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node inject-css-import.js",
        "cwd": "packages/checkbox"
      },
      "inputs": ["{projectRoot}/packages/checkbox/dist"],
      "output": "{projectRoot}/packages/checkbox/dist"
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run checkbox:compile",
          "nx run checkbox:post-compile"
        ],
        "parallel": false
      },
      "outputs": ["{projectRoot}/packages/checkbox/dist"]
    }
  }
}
